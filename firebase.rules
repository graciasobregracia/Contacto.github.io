rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorizedViewer() {
      return request.auth != null
        && exists(/databases/$(database)/documents/authorized_viewers/$(request.auth.token.email))
        && get(/databases/$(database)/documents/authorized_viewers/$(request.auth.token.email)).data.active == true;
    }

    match /solicitudes/{document} {
      allow create: if true;
      allow read: if isAuthorizedViewer();
      allow update: if false;
      allow delete: if isAuthorizedViewer();
    }

    match /solicitudes_eliminadas/{document} {
      allow create: if isAuthorizedViewer();
      allow update: if false;
      allow read, delete: if false;
    }

    match /authorized_viewers/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }
  }
}
